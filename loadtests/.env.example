# URL for host/manual executions (outside Docker network)
TARGET_URL=https://localhost

# URL used by containers in docker-compose.loadtest.yml
# IMPORTANT: inside Docker network use service name, not localhost
TARGET_URL_DOCKER=https://nginx

# Skip TLS certificate verification in k6.
# Keep true for local self-signed certificates, false for valid certs.
K6_INSECURE_TLS=true

# Prometheus remote write endpoint (for k6 metrics → Grafana)
K6_PROMETHEUS_RW_SERVER_URL=http://prometheus:9090/api/v1/write

# Test user credentials base
LOADTEST_USERNAME=loadtest_user
LOADTEST_PASSWORD=loadtest_pass_123

# Number of pre-created users in game.js setup
GAME_SETUP_VUS=50