{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "module": "node18",
    "target": "ES2022",
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "strict": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["__tests__/**", "dist/**", "node_modules/**"]
}