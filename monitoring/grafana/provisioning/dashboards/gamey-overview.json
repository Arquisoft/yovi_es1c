      "title": "Resumen",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "Métricas del motor `gamey`: salud del scrape y latencia de respuesta del bot, desglosada por `bot_id` para comparar dificultades y endpoints durante pruebas de carga."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Prometheus scrape up",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(up{job=\"gamey-service\"})",
          "instant": true
        }
