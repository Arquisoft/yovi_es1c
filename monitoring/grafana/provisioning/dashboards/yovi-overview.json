{
  "id": null,
  "uid": "yovi-overview",
  "title": "YOVI Overview",
  "tags": ["yovi", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Games",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "gameservice_active_games_total"}]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Games Created Rate (5m)",
      "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "rate(gameservice_games_created_total[5m])"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Socket Connections Active",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "gameservice_socket_connections_active"}]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Bot Move Duration (p95)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "histogram_quantile(0.95, sum(rate(gameservice_bot_move_duration_seconds_bucket[5m])) by (le))"}]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Matchmaking Duration (p95)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "histogram_quantile(0.95, sum(rate(gameservice_matchmaking_duration_seconds_bucket[5m])) by (le))"}]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Request Rate per Service",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (job) (rate(http_requests_total[5m]))"},
        {"refId": "B", "expr": "sum by (job) (rate(auth_http_requests_total[5m]))"}
      ]
    }
  ]
}