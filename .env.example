# Image tag for the deployed containers
IMAGE_TAG=latest

# Public hostname used by Grafana when generating absolute URLs behind nginx
# Local default can remain localhost; set this to your public DNS name for remote deploys
PUBLIC_HOST=localhost
# Secret key used to sign JWT tokens for authentication
JWT_SECRET=yovi_es1c_2526

# Database passwords for PostgreSQL services
AUTH_DB_PASSWORD=changeme
GAME_DB_PASSWORD=changeme
# Backend Service Endpoints
VITE_GAME_ENGINE_API_URL=/api/gamey   # Rust game engine (stateless logic)
VITE_GAME_SERVICE_API_URL=/api/game    # Game persistence service (matches, stats)
VITE_AUTH_API_URL=/api/auth            # Authentication service
VITE_USERS_API_URL=/api/users          # User profile service
# DuckDNS
DUCKDNS_TOKEN=tu-token-de-duckdns
DUCKDNS_DOMAIN=yovi-es1c
CERTBOT_EMAIL=tu@email.com
